#!/bin/bash
################################################################################
# CVG Compliance — Pre-Commit Hook
# Blocks commits containing prohibited content
#
# Installation:
#   1. Save this file as .git/hooks/pre-commit
#   2. chmod +x .git/hooks/pre-commit
#   3. Test: git commit with prohibited content → BLOCKED
#
# Bypass (emergency only):
#   git commit --no-verify
################################################################################

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Patterns to block
declare -a PATTERNS=(
    # Internal IPs
    '10\.10\.10\.\d+'
    '192\.168\.\d+\.\d+'
    '172\.[1-3][0-9]\.\d+\.\d+'
    
    # Internal domains
    'cleargeo\.tech'
    'cleargeo365\.onmicrosoft\.com'
    'pve\.cleargeo\.tech'
    'git\.cleargeo\.tech'
    'cvg-nexus\.com'
    
    # Known credentials
    'CVGadmin2026!'
    'CVGproc1!2026'
    '7ffbb3fc2ea62e6c556b4c10e699d769f0d41e7a'
    'd0af97b6-36df-49e7-82dc-ed37a8c4f3ff'
    'PVEAPIToken='
    
    # SSH/API keys
    'BEGIN RSA PRIVATE KEY'
    'BEGIN OPENSSH PRIVATE KEY'
    'END.*PRIVATE KEY'
    'PRIVATE KEY'
    'SECRET_KEY='
    'AWS_SECRET_ACCESS_KEY='
    'AZURE_CLIENT_SECRET'
)

VIOLATIONS=0
STAGED_FILES=$(git diff --cached --name-only 2>/dev/null || echo "")

if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

for FILE in $STAGED_FILES; do
    # Skip binary files
    if file "$FILE" 2>/dev/null | grep -q "binary"; then
        continue
    fi
    
    CONTENT=$(git show ":$FILE" 2>/dev/null || cat "$FILE" 2>/dev/null || echo "")
    
    for PATTERN in "${PATTERNS[@]}"; do
        if echo "$CONTENT" | grep -qPE "$PATTERN"; then
            echo -e "${RED}❌ BLOCKED${NC}: Pattern '$PATTERN' found in $FILE"
            VIOLATIONS=$((VIOLATIONS + 1))
        fi
    done
done

if [ $VIOLATIONS -gt 0 ]; then
    echo ""
    echo -e "${RED}═══════════════════════════════════════════════════════════${NC}"
    echo -e "${RED}CVG COMPLIANCE VIOLATION: Commit rejected${NC}"
    echo -e "${RED}Found $VIOLATIONS prohibited pattern(s)${NC}"
    echo ""
    echo -e "${YELLOW}Why this happened:${NC}"
    echo "  This repository contains proprietary CVG infrastructure code."
    echo "  Commits are scanned for accidental credential or IP disclosure."
    echo ""
    echo -e "${YELLOW}What to do:${NC}"
    echo "  1. Review the flagged files above"
    echo "  2. Remove prohibited content (IPs, credentials, domains)"
    echo "  3. Stage changes: git add <files>"
    echo "  4. Commit again: git commit -m '<message>'"
    echo ""
    echo -e "${YELLOW}Emergency bypass (use sparingly):${NC}"
    echo "  git commit --no-verify"
    echo "  ⚠️  Only if you are absolutely sure the content is safe"
    echo -e "${RED}═══════════════════════════════════════════════════════════${NC}"
    exit 1
fi

echo -e "${GREEN}✓ Pre-commit check passed${NC}"
exit 0