# ============================================================
# CVG Neuron AI Orchestration System — Environment Config
# Version: 2.0.0 | Clearview Geographic LLC
# Copy this file to .env and fill in values
# ============================================================

# --- Application ---
APP_NAME="CVG Neuron"
APP_VERSION="2.0.0"
ENVIRONMENT="development"   # development | staging | production
DEBUG=true

# --- Neuron Identity ---
NEURON_ID="CVG-NEURON-001"
NEURON_EMPLOYEE_ID="CVG-AI-001"
NEURON_PRIMARY_HIVE="HIVE-0"
NEURON_PRIMARY_QUEEN="CVG-QUEEN-13"

# --- Network ---
HOST="0.0.0.0"
PORT=8808
WORKERS=4

# --- Security / JWT ---
SECRET_KEY="CHANGE_ME_generate_with_openssl_rand_hex_32"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Database ---
DATABASE_URL="postgresql+asyncpg://neuron:password@localhost:5432/cvg_neuron"
DATABASE_ECHO=false

# --- Redis Cache ---
REDIS_URL="redis://localhost:6379/0"
REDIS_PASSWORD=""
CACHE_TTL_SECONDS=3600
NEURO_CACHE_MAX_SIZE=512
NEURO_CACHE_STRATEGY="LRU"    # LRU | LFU | FIFO

# --- CVG Hive (Distributed Compute) ---
HIVE_ENDPOINT="http://192.168.100.38:8808/api/hive/coordinate"
HIVE_NODE_0="192.168.100.38"
HIVE_NODE_1="192.168.100.39"
HIVE_NODE_2="192.168.100.40"
HIVE_TIMEOUT=30
HIVE_RETRIES=3

# --- CVG COMB (Tiered Memory) ---
COMB_ENDPOINT="http://192.168.100.38:8808/api/comb/store"
COMB_POLLEN_STORE="http://192.168.100.38:8808/api/comb/pollen"
COMB_BIT_HIVE="http://192.168.100.38:8808/api/comb/bithive"
COMB_WAX_CELL="http://192.168.100.38:8808/api/comb/waxcell"

# --- CVG Observability ---
OBSERVABILITY_ENDPOINT="http://192.168.100.38:9090/api/metrics"
OBSERVABILITY_ENABLED=true
METRICS_PORT=9091

# --- CVG Network ---
NETWORK_ENDPOINT="http://192.168.100.38:8808/api/network"

# --- CVG StratoVault (Security) ---
STRATOVAULT_ENDPOINT="http://192.168.100.38:8443/api/auth"
STRATOVAULT_ENABLED=false

# --- AI Providers ---
# OpenAI
OPENAI_API_KEY="sk-..."
OPENAI_DEFAULT_MODEL="gpt-4o"

# Anthropic
ANTHROPIC_API_KEY="sk-ant-..."
ANTHROPIC_DEFAULT_MODEL="claude-3-5-sonnet-20241022"

# Ollama (local)
OLLAMA_BASE_URL="http://192.168.100.38:11434"
OLLAMA_DEFAULT_MODEL="llama3.2"

# Default AI Provider: openai | anthropic | ollama
DEFAULT_AI_PROVIDER="ollama"

# --- Cognitive Processing ---
DEFAULT_COGNITIVE_LEVEL="advanced"  # basic | advanced | neural | autonomous
MAX_CONCURRENT_TASKS=20
TASK_TIMEOUT_SECONDS=300

# --- Logging ---
LOG_LEVEL="INFO"    # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT="json"   # json | text
LOG_FILE="logs/neuron.log"

# --- CORS ---
CORS_ORIGINS="*"
CORS_ALLOW_CREDENTIALS=true
